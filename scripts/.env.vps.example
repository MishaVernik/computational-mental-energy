# scripts/.env.vps -- read by Install-VpsServices.ps1 and passed to cme-api as env vars.
# Copy this file to scripts/.env.vps (gitignored) and fill in values.
#
# ALL FIELDS BELOW ARE OPTIONAL. Leave the whole file empty or do not create it at all
# to disable Azure Digital Twins sync -- the API falls back to NoOpDigitalTwinSyncService
# and the streaming demo still works end-to-end (phone -> bridge -> API -> dashboard).
#
# To enable ADT sync on the VPS, mint a Service Principal locally (where `az login`
# is available) and paste the four values below. See docs/vps_deployment.md.
#
#   $adtId = az dt show --dt-name cme --resource-group AzureForStartups --query id -o tsv
#   az ad sp create-for-rbac --name "cme-vps-sp" --role "Azure Digital Twins Data Owner" --scopes $adtId
#
# Format: KEY=VALUE, one per line. Lines starting with `#` are comments. No quoting needed.

# AzureDigitalTwins__Endpoint=https://cme.api.wcus.digitaltwins.azure.net
# AzureDigitalTwins__TenantId=00000000-0000-0000-0000-000000000000
# AzureDigitalTwins__ClientId=00000000-0000-0000-0000-000000000000
# AzureDigitalTwins__ClientSecret=replace-with-sp-secret

# Optional ADT tuning (defaults from appsettings.json are usually fine):
# AzureDigitalTwins__SyncIntervalSeconds=30
# AzureDigitalTwins__DiffOnly=true
# AzureDigitalTwins__UserTwinId=user-default
# AzureDigitalTwins__HeadbandTwinId=headband-default
